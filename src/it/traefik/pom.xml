<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>io.kokuwa.maven</groupId>
		<artifactId>k3s-maven-plugin-it</artifactId>
		<version>LOCAL-SNAPSHOT</version>
	</parent>

	<artifactId>k3s-maven-plugin-it-traefik</artifactId>

	<properties>
		<k3s.manifests>${project.build.directory}/k3s</k3s.manifests>
	</properties>

	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-resources-plugin</artifactId>
				<executions>
					<execution>
						<id>k3s</id>
						<phase>pre-integration-test</phase>
						<goals>
							<goal>copy-resources</goal>
						</goals>
						<configuration>
							<resources>
								<resource>
									<directory>${project.basedir}/src/test/k3s</directory>
									<filtering>true</filtering>
								</resource>
							</resources>
							<outputDirectory>${project.build.directory}/k3s</outputDirectory>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-failsafe-plugin</artifactId>
				<configuration>
					<systemPropertyVariables>
						<k3s.hostname>${k3s.hostname}</k3s.hostname>
					</systemPropertyVariables>
				</configuration>
			</plugin>
			<plugin>
				<groupId>io.kokuwa.maven</groupId>
				<artifactId>k3s-maven-plugin</artifactId>
				<executions>
					<execution>
						<goals>
							<goal>hostname</goal>
							<goal>run</goal>
							<goal>apply</goal>
							<goal>debug</goal>
							<goal>rm</goal>
						</goals>
					</execution>
				</executions>
				<configuration>
					<portBindings>
						<portBinding>8080:8080</portBinding>
					</portBindings>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
